---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const work = (await getCollection("work", ({ data }) => data.status === "published"))
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Work" description="Selected systems, research, and independent work by Noah Airmet.">
  <header class="page-hero">
    <p class="indexed-label"><span>01</span> Selected work</p>
    <h1>Work close enough to the system to see where governance breaks.</h1>
    <p>
      These are not polished product claims. They are working studies in how
      data, authority, review, and responsibility behave when software and AI
      meet real institutions.
    </p>
  </header>

  <div class="page-content">
    <div class="work-feature-list">
      {work.filter(({ data }) => !data.independent).map((entry, index) => (
        <article class="work-feature">
          <p class="work-index">{String(index + 1).padStart(2, "0")} / {entry.data.eyebrow}</p>
          <div>
            <p class="work-kind">{entry.data.scope}</p>
            <h3><a href={`/work/${entry.id}/`}>{entry.data.title}</a></h3>
            <p>{entry.data.description}</p>
          </div>
          <a class="round-link" href={`/work/${entry.id}/`} aria-label={`Read ${entry.data.title}`}>↗</a>
        </article>
      ))}
    </div>

    {work.filter(({ data }) => data.independent).map((entry) => (
      <aside class="independent-project">
        <p class="work-kind">Independent work, kept distinct</p>
        <h3>{entry.data.title}</h3>
        <p>{entry.data.description}</p>
        <a href={entry.data.externalUrl}>Visit project <span aria-hidden="true">↗</span></a>
      </aside>
    ))}
  </div>
</BaseLayout>
