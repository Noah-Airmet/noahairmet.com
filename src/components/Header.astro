---
import { site } from "../lib/site";

const path = Astro.url.pathname;
const navItems = [
  { href: "/work/", label: "Work" },
  { href: "/about/", label: "About" },
  { href: "/resume/", label: "Résumé" },
];
---

<header class="site-header">
  <a class="site-name" href="/" aria-label="Noah Airmet, home">
    <span class="site-mark" aria-hidden="true">NA</span>
    <span>Noah Airmet</span>
  </a>
  <p class="site-descriptor">Software × Security × Governance</p>
  <nav aria-label="Primary">
    <ul>
      {navItems.map((item) => (
        <li><a href={item.href} aria-current={path.startsWith(item.href) ? "page" : undefined}>{item.label}</a></li>
      ))}
      <li><a class="nav-contact" href={`mailto:${site.email}`}>Contact</a></li>
    </ul>
  </nav>
</header>
