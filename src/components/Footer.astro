---
import { site } from "../lib/site";
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div>
    <p class="footer-name">{site.name}</p>
    <p>Software development, cybersecurity, and practical AI governance.</p>
  </div>
  <p class="footer-status"><span aria-hidden="true"></span> Open to 2027 opportunities</p>
  <nav aria-label="Footer">
    <ul>
      <li><a href={`mailto:${site.email}`}>Email</a></li>
      <li><a href="/colophon/">Colophon</a></li>
      <li><a href="/privacy/">Privacy</a></li>
      <li><a href={site.github} rel="me">GitHub</a></li>
      <li><a href={site.linkedin} rel="me">LinkedIn</a></li>
    </ul>
  </nav>
  <p class="footer-meta">&copy; {year} · Provo, Utah</p>
</footer>
